# --- Built frontend (generated) ---
# Ignores Vite/React build outputs
frontend/dist/
app/frontend_dist/*
!app/frontend_dist/.gitkeep

# --- AI Models (Global) ---
# Prevents accidental upload of heavy neural weights
*.onnx
*.pth
*.pt
*.ckpt
*.safetensors
*.bin
*.model
models/*
app/models/*
frontend/public/models/**/*
wav2vec2-datasetstt02/
!models/.gitkeep
!app/models/.gitkeep

# --- Databases & Local Data ---
app/data/*.db
app/data/*.db-shm
app/data/*.db-wal
*.sqlite3

# --- Python & Test "Trash" ---
__pycache__/
app/text/__pycache__/
tests/__pycache__/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/
.coverage
.coverage.*
htmlcov/
*.py[cod]
*$py.class

# --- Environments ---
venv/
