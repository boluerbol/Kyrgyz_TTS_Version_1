# Core secrets
GROQ_API_KEY=replace_with_real_key
JWT_SECRET=replace_with_very_long_random_secret

# SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@example.com
SMTP_PASSWORD=replace_with_app_password
SMTP_FROM=your_email@example.com

# Live STT options
LIVE_STT_MODEL=groq/whisper-large-v3-turbo
LIVE_LOCAL_STT_PATH=/app/wav2vec2-datasetstt02/wav2vec2-datasetstt

# Database (compose defaults are fine, override if needed)
POSTGRES_DB=kyrgyz_ai
POSTGRES_USER=kyrgyz
POSTGRES_PASSWORD=kyrgyz_password
DATABASE_URL=postgresql+psycopg2://kyrgyz:kyrgyz_password@db:5432/kyrgyz_ai
